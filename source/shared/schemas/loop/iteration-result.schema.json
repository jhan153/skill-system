{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skill-system-loop-iteration-result.schema.json",
  "title": "Skill System Loop Iteration Result",
  "type": "object",
  "required": ["schema_version", "loop_run_id", "iteration", "condition_results"],
  "properties": {
    "schema_version": { "enum": [1] },
    "loop_run_id": {
      "type": "string",
      "pattern": "^LR-[0-9]{8}-[0-9]{3}$"
    },
    "iteration": { "type": "integer", "minimum": 1 },
    "iteration_result_id": { "type": "string", "minLength": 1 },
    "payload_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "agent_run_id": { "type": "string" },
    "condition_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["condition_id", "status", "evidence_refs"],
        "properties": {
          "condition_id": {
            "type": "string",
            "pattern": "^SC-[0-9]{3}$"
          },
          "status": { "enum": ["pass", "fail", "unverified", "blocked"] },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "failure_fingerprint": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "side_effects": { "type": "array" }
  },
  "additionalProperties": false
}
