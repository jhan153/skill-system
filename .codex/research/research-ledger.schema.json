{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skill-system-research-ledger.schema.json",
  "title": "Skill System Research Evidence Ledger",
  "type": "object",
  "required": [
    "schema_version",
    "ledger_id",
    "topic",
    "created_at",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "ledger_id": {
      "type": "string",
      "pattern": "^RL-[0-9]{8}-[0-9]{3}$"
    },
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "entry_id",
          "source_id",
          "claim",
          "evidence_role",
          "citation_status",
          "verification_status",
          "local_consumers"
        ],
        "properties": {
          "entry_id": {
            "type": "string",
            "pattern": "^RLE-[0-9]{3}$"
          },
          "source_id": {
            "type": "string",
            "minLength": 1
          },
          "claim": {
            "type": "string",
            "minLength": 1
          },
          "evidence_role": {
            "enum": [
              "supports",
              "contradicts",
              "background",
              "method"
            ]
          },
          "citation_status": {
            "enum": [
              "verified",
              "needs-refresh",
              "provided-by-user",
              "unverified"
            ]
          },
          "verification_status": {
            "enum": [
              "agent-verified",
              "user-verification-needed",
              "unverified"
            ]
          },
          "local_consumers": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
