{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skill-system-lifecycle-event.schema.json",
  "title": "Harness Lifecycle Event Mapping",
  "type": "object",
  "required": [
    "mapping"
  ],
  "properties": {
    "mapping": {
      "type": "object",
      "required": [
        "neutral_event",
        "host",
        "host_event",
        "support_level"
      ],
      "properties": {
        "neutral_event": {
          "enum": [
            "request_received",
            "context_loaded",
            "tool_preflight",
            "permission_requested",
            "tool_result",
            "tool_batch_completed",
            "turn_finalize_attempt",
            "turn_finalize",
            "compact_before",
            "compact_after"
          ]
        },
        "host": {
          "enum": [
            "codex",
            "claude"
          ]
        },
        "host_event": {
          "type": "string"
        },
        "support_level": {
          "enum": [
            "native",
            "approximate",
            "unsupported"
          ]
        },
        "fallback_strategy": {
          "type": "string"
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "lifecycle_event_v2": {
      "type": "object",
      "required": [
        "schema_version",
        "run_id",
        "seq",
        "prev_event_hash",
        "event_hash",
        "recorded_at",
        "neutral_event",
        "host",
        "host_event",
        "support_level",
        "status",
        "evidence"
      ],
      "properties": {
        "schema_version": {
          "const": 2
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "seq": {
          "type": "integer",
          "minimum": 1
        },
        "prev_event_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "event_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "recorded_at": {
          "type": "string",
          "format": "date-time"
        },
        "neutral_event": {
          "enum": [
            "request_received",
            "context_loaded",
            "tool_preflight",
            "permission_requested",
            "tool_result",
            "tool_batch_completed",
            "turn_finalize_attempt",
            "turn_finalize",
            "compact_before",
            "compact_after"
          ]
        },
        "host": {
          "enum": [
            "codex",
            "claude"
          ]
        },
        "host_event": {
          "type": "string",
          "minLength": 1
        },
        "support_level": {
          "enum": [
            "native",
            "approximate",
            "unsupported"
          ]
        },
        "tool_id": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "turn_id": {
          "type": "string"
        },
        "tool_use_id": {
          "type": "string"
        },
        "status": {
          "enum": [
            "pass",
            "warn",
            "fail",
            "skip"
          ]
        },
        "evidence": {
          "type": "object"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
