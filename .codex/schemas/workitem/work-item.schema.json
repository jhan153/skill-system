{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skill-system-work-item.schema.json",
  "title": "Skill System WorkItem Lifecycle",
  "type": "object",
  "required": [
    "schema_version",
    "work_item_id",
    "title",
    "source",
    "state",
    "owner",
    "runtime_boundary",
    "history",
    "evidence_refs",
    "open_findings",
    "next_action"
  ],
  "properties": {
    "schema_version": { "enum": [1] },
    "work_item_id": {
      "type": "string",
      "pattern": "WI-[0-9]{8}-[0-9]{3}"
    },
    "title": { "type": "string", "minLength": 1 },
    "source": {
      "type": "object",
      "required": ["type", "ref"],
      "properties": {
        "type": {
          "enum": ["user_request", "plan", "kanboard", "issue", "agent_finding", "field_feedback"]
        },
        "ref": { "type": "string" }
      },
      "additionalProperties": false
    },
    "state": {
      "enum": ["triage", "explore", "ready", "implement", "verify", "review", "blocked", "closed"]
    },
    "owner": { "enum": ["human", "agent", "external"] },
    "primary_skill": { "type": ["string", "null"] },
    "task_run_ref": { "type": ["string", "null"] },
    "loop_run_ref": { "type": ["string", "null"] },
    "runtime_boundary": {
      "type": "object",
      "required": [
        "mode",
        "queue_runtime",
        "scheduler_runtime",
        "kanboard_source_of_truth",
        "looprun_replacement"
      ],
      "properties": {
        "mode": { "enum": ["state_model"] },
        "queue_runtime": { "const": false },
        "scheduler_runtime": { "const": false },
        "kanboard_source_of_truth": { "const": false },
        "looprun_replacement": { "const": false }
      },
      "additionalProperties": false
    },
    "history": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["state", "at", "actor", "evidence_refs"],
        "properties": {
          "state": {
            "enum": ["triage", "explore", "ready", "implement", "verify", "review", "blocked", "closed"]
          },
          "at": { "type": "string" },
          "actor": { "enum": ["human", "agent", "external"] },
          "note": { "type": "string" },
          "evidence_refs": { "type": "array", "items": { "type": "object" } }
        },
        "additionalProperties": false
      }
    },
    "evidence_refs": { "type": "array", "items": { "type": "object" } },
    "open_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "severity", "status", "evidence_refs"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string" },
          "severity": { "enum": ["low", "medium", "high", "critical"] },
          "status": { "enum": ["open", "blocked", "resolved", "accepted_risk"] },
          "evidence_refs": { "type": "array", "items": { "type": "object" } },
          "resolution": { "type": "string" },
          "accepted_by": { "enum": ["user", "project_policy"] },
          "reason": { "type": "string" },
          "review_at": { "type": "string" }
        },
        "additionalProperties": false,
        "allOf": [
          {
            "comment": "accepted_risk findings must record who accepted them and why",
            "if": { "properties": { "status": { "const": "accepted_risk" } }, "required": ["status"] },
            "then": { "required": ["accepted_by", "reason", "review_at"] }
          },
          {
            "comment": "resolved findings need a resolution and evidence",
            "if": { "properties": { "status": { "const": "resolved" } }, "required": ["status"] },
            "then": { "required": ["resolution"], "properties": { "evidence_refs": { "minItems": 1 } } }
          }
        ]
      }
    },
    "blocked_reason": { "type": "string" },
    "next_action": { "type": "string" }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "comment": "closed WorkItems need evidence",
      "if": { "properties": { "state": { "const": "closed" } }, "required": ["state"] },
      "then": { "properties": { "evidence_refs": { "minItems": 1 } } }
    },
    {
      "comment": "blocked WorkItems need a reason and next action",
      "if": { "properties": { "state": { "const": "blocked" } }, "required": ["state"] },
      "then": { "required": ["blocked_reason"], "properties": { "next_action": { "minLength": 1 } } }
    }
  ]
}
