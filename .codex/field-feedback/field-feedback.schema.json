{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skill-system-field-feedback.schema.json",
  "title": "Skill System Field Feedback",
  "type": "object",
  "required": [
    "feedback_id",
    "bundle_version",
    "bundle_hash_or_commit",
    "date",
    "host",
    "host_version",
    "model",
    "request_class",
    "expected_primary_skill",
    "actual_primary_skill",
    "artifact_refs",
    "validation_evidence",
    "outcome",
    "friction",
    "privacy_redactions"
  ],
  "properties": {
    "feedback_id": {
      "type": "string",
      "pattern": "^FF-[0-9]{8}-[0-9]{3}$"
    },
    "bundle_version": {
      "type": "string"
    },
    "bundle_hash_or_commit": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "host": {
      "type": "string"
    },
    "host_version": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "request_class": {
      "type": "string"
    },
    "expected_primary_skill": {
      "type": "string"
    },
    "actual_primary_skill": {
      "type": "string"
    },
    "artifact_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "validation_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "outcome": {
      "enum": [
        "pass",
        "partial",
        "fail"
      ]
    },
    "friction": {
      "type": "string"
    },
    "privacy_redactions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
