{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skill-system-knowledge-source.schema.json",
  "title": "Skill System Knowledge Source Store",
  "type": "object",
  "required": [
    "schema_version",
    "store_id",
    "sources"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "store_id": {
      "type": "string",
      "pattern": "^KS-[0-9]{8}-[0-9]{3}$"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "source_id",
          "source_kind",
          "locator_type",
          "locator",
          "content_digest",
          "retrieved_at",
          "authority_tier",
          "verification_status",
          "freshness",
          "lifecycle_state"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "pattern": "^SRC-[0-9]{8}-[0-9]{3}$"
          },
          "source_kind": {
            "enum": [
              "repo_file",
              "plan_document",
              "kanboard_card",
              "agent_run",
              "user_decision",
              "research_source",
              "generated_artifact",
              "external_primary",
              "transient_input"
            ]
          },
          "locator_type": {
            "enum": [
              "repo_path",
              "web_url",
              "kanboard_card",
              "agent_run",
              "attachment",
              "generated_artifact"
            ]
          },
          "locator": {
            "type": "string",
            "minLength": 1
          },
          "content_digest": {
            "type": "object",
            "required": [
              "algorithm",
              "value"
            ],
            "properties": {
              "algorithm": {
                "const": "sha256"
              },
              "value": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              }
            },
            "additionalProperties": false
          },
          "retrieved_at": {
            "type": "string",
            "format": "date-time"
          },
          "authority_tier": {
            "enum": [
              "authoritative",
              "user_decision",
              "operational_state",
              "evidence",
              "external",
              "transient"
            ]
          },
          "verification_status": {
            "enum": [
              "agent-verified",
              "user-verification-needed",
              "unverified"
            ]
          },
          "freshness": {
            "enum": [
              "current",
              "stale",
              "superseded"
            ]
          },
          "lifecycle_state": {
            "enum": [
              "active",
              "archived",
              "superseded",
              "transient"
            ]
          },
          "metadata": {
            "type": "object",
            "properties": {
              "plan_lifecycle": {
                "enum": [
                  "active",
                  "completed",
                  "blocked",
                  "superseded",
                  "archived"
                ]
              },
              "kanboard_status": {
                "enum": [
                  "active",
                  "blocked",
                  "done",
                  "archived"
                ]
              },
              "kanboard_card_id": {
                "type": "string",
                "minLength": 1
              },
              "source_role": {
                "enum": [
                  "active_anchor",
                  "closeout_candidate",
                  "operational_state",
                  "historical_evidence"
                ]
              }
            },
            "additionalProperties": false
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
