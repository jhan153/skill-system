{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skill-system-knowledge-feedback-packet.schema.json",
  "title": "Skill System Knowledge Feedback Packet",
  "type": "object",
  "required": [
    "schema_version",
    "packet_id",
    "source_run_id",
    "created_at",
    "review_state",
    "proposals"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "packet_id": {
      "type": "string",
      "pattern": "^FP-[0-9]{8}-[0-9]{3}$"
    },
    "source_run_id": {
      "type": "string",
      "pattern": "^AR-[0-9]{8}-[0-9]{3}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "review_state": {
      "enum": [
        "proposed",
        "accepted",
        "rejected"
      ]
    },
    "proposals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "proposal_id",
          "proposal_type",
          "rationale",
          "evidence_refs"
        ],
        "properties": {
          "proposal_id": {
            "type": "string",
            "pattern": "^KFP-[0-9]{3}$"
          },
          "proposal_type": {
            "enum": [
              "add_claim",
              "update_claim",
              "add_edge",
              "supersede_claim",
              "note_conflict"
            ]
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "candidate_claim": {
            "type": "object",
            "properties": {
              "claim_type": {
                "type": "string"
              },
              "statement": {
                "type": "string"
              },
              "source_refs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          },
          "candidate_edge": {
            "type": "object",
            "properties": {
              "from_claim_id": {
                "type": "string"
              },
              "to_claim_id": {
                "type": "string"
              },
              "relation_type": {
                "type": "string"
              },
              "source_refs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
