{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skill-system-loop-contract.schema.json",
  "title": "Skill System Loop Contract",
  "type": "object",
  "required": ["schema_version", "contract_id", "activation", "goal", "control", "termination"],
  "properties": {
    "schema_version": { "enum": [1] },
    "contract_id": {
      "type": "string",
      "pattern": "^LC-[0-9]{8}-[0-9]{3}$"
    },
    "activation": { "enum": ["explicit"] },
    "goal": {
      "type": "object",
      "required": ["statement", "success_conditions"],
      "properties": {
        "statement": { "type": "string", "minLength": 1 },
        "success_conditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "statement", "verifier"],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^SC-[0-9]{3}$"
              },
              "statement": { "type": "string", "minLength": 1 },
              "required": { "type": "boolean" },
              "verifier": {
                "type": "object",
                "required": ["type"],
                "properties": {
                  "type": {
                    "enum": ["command_exit", "artifact_exists", "manual_check", "diff_scope"]
                  },
                  "command": { "type": "string" },
                  "expected_exit_code": { "type": "integer" },
                  "path": { "type": "string" }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        },
        "invariants": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "statement", "verifier"],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^INV-[0-9]{3}$"
              },
              "statement": { "type": "string", "minLength": 1 },
              "verifier": { "type": "object" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "scope": { "type": "object" },
    "control": {
      "type": "object",
      "required": ["max_iterations", "no_progress_limit", "same_failure_limit", "max_stop_continuations"],
      "properties": {
        "max_iterations": { "type": "integer", "minimum": 1 },
        "max_wall_time_seconds": { "type": "integer", "minimum": 0 },
        "no_progress_limit": { "type": "integer", "minimum": 1 },
        "same_failure_limit": { "type": "integer", "minimum": 1 },
        "oscillation_limit": { "type": "integer", "minimum": 1 },
        "max_stop_continuations": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "recovery": { "type": "object" },
    "termination": {
      "type": "object",
      "required": ["precedence"],
      "properties": {
        "precedence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["unsafe", "fatal", "blocked", "success", "approval_required", "stalled", "budget_exhausted", "recover", "continue"]
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
